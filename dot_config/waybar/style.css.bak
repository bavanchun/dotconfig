/* ── Catppuccin Mocha palette ─────────────────────────────── */
@define-color base    #1e1e2e;
@define-color mantle  #181825;
@define-color crust   #11111b;
@define-color surface0 #313244;
@define-color surface1 #45475a;
@define-color overlay0 #6c7086;
@define-color text    #cdd6f4;
@define-color subtext #a6adc8;
@define-color blue    #89b4fa;
@define-color lavender #b4befe;
@define-color sapphire #74c7ec;
@define-color sky     #89dceb;
@define-color teal    #94e2d5;
@define-color green   #a6e3a1;
@define-color yellow  #f9e2af;
@define-color peach   #fab387;
@define-color red     #f38ba8;
@define-color mauve   #cba6f7;

/* ── Global ───────────────────────────────────────────────── */
* {
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 13px;
    min-height: 0;
    border: none;
    border-radius: 0;
}

window#waybar {
    background-color: alpha(@base, 0.85);
    color: @text;
    border-bottom: 2px solid alpha(@surface1, 0.5);
    transition-property: background-color;
    transition-duration: 0.3s;
}

/* ── Tooltip ──────────────────────────────────────────────── */
tooltip {
    background-color: @mantle;
    border: 1px solid @surface1;
    border-radius: 8px;
    color: @text;
}

/* ── Workspaces ───────────────────────────────────────────── */
#workspaces {
    margin: 4px 6px;
    padding: 0;
}

#workspaces button {
    padding: 0 8px;
    margin: 2px 2px;
    border-radius: 6px;
    color: @subtext;
    background-color: @surface0;
    transition: all 0.2s ease;
}

#workspaces button:hover {
    background-color: @surface1;
    color: @text;
}

#workspaces button.active {
    background-color: @blue;
    color: @base;
    font-weight: bold;
}

#workspaces button.urgent {
    background-color: @red;
    color: @base;
}

/* ── Window title ─────────────────────────────────────────── */
#window {
    padding: 0 12px;
    color: @subtext;
    font-style: italic;
}

/* ── Clock ────────────────────────────────────────────────── */
#clock {
    padding: 0 14px;
    color: @blue;
    font-weight: bold;
}

/* ── Shared module style ──────────────────────────────────── */
#idle_inhibitor,
#wireplumber,
#network,
#bluetooth,
#cpu,
#memory,
#backlight,
#battery,
#tray,
#custom-swaync {
    padding: 0 10px;
    margin: 4px 2px;
    border-radius: 6px;
    background-color: @surface0;
    color: @text;
}

/* ── Per-module colors ────────────────────────────────────── */
#idle_inhibitor { color: @overlay0; }
#idle_inhibitor.activated { color: @yellow; }

#wireplumber { color: @sapphire; }
#wireplumber.muted { color: @overlay0; }

#network { color: @teal; }
#network.disconnected { color: @red; }

#bluetooth { color: @blue; }
#bluetooth.disabled { color: @overlay0; }

#cpu { color: @peach; }
#memory { color: @mauve; }
#backlight { color: @yellow; }

#battery { color: @green; }
#battery.warning { color: @yellow; }
#battery.critical { color: @red; }
#battery.critical:not(.charging) {
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: steps(12);
    animation-iteration-count: infinite;
    animation-direction: alternate;
}
#battery.charging { color: @green; }
#battery.plugged   { color: @teal; }

@keyframes blink {
    to { color: @base; background-color: @red; }
}

#tray { background-color: transparent; }
#tray > .passive { -gtk-icon-effect: dim; }
#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: @red;
    border-radius: 6px;
}

#custom-fcitx { color: @green; }

#custom-swaync { color: @lavender; }
