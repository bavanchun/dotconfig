{
    "output": "eDP-1",
    "layer": "top",
    "position": "top",
    "height": 48,
    "spacing": 0,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["custom/launcher", "clock", "group/resources", "custom/active-window", "group/media"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["group/tray-menu", "custom/swaync", "battery", "wireplumber", "backlight", "custom/control", "custom/power"],

    "group/media": {
        "orientation": "horizontal",
        "modules": ["custom/media"]
    },
    "group/resources": {
        "orientation": "horizontal",
        "modules": ["custom/res-toggle", "temperature", "cpu", "memory"],
        "drawer": {
            "transition-duration": 220,
            "children-class": "res-items"
        }
    },

    // Connectivity: drawer â€” chل»‰ hiل»‡n icon toggle, hover mل»›i mل»ں
    "group/connectivity": {
        "orientation": "horizontal",
        "modules": ["custom/conn-toggle", "idle_inhibitor", "network", "bluetooth"],
        "drawer": {
            "transition-duration": 220,
            "children-class": "conn-items"
        }
    },

    "group/tray-menu": {
        "orientation": "horizontal",
        "modules": ["custom/tray-toggle", "tray"],
        "drawer": {
            "transition-duration": 220,
            "children-class": "tray-items"
        }
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "format-empty": "â€¢",
        "format-window-separator": " ",
        "window-rewrite-default-icon": "َ°£†",
        "window-rewrite": {
            "google-chrome": "َ°ٹ­",
            "Alacritty": "",
            "alacritty": "",
            "code": "َ°¨‍",
            "code-url-handler": "َ°¨‍",
            "thunar": "َ°‰‹",
            "nautilus": "َ°‰‹",
            "discord": "َ°™¯",
            "telegram-desktop": "َ°”پ",
            "vlc": "َ°•¼",
            "mpv": "",
            "obs": "َ°‘‹",
            "gimp-2.10": "",
            "inkscape": "",
            "libreoffice-writer": "َ°ˆ™",
            "libreoffice-calc": "َ°ˆ›",
            "libreoffice-impress": "َ°گ©",
            "spotify": "َ°“‡",
            "steam": "َ°““",
            "pavucontrol": "َ°•¾",
            "blueman-manager": "َ°‚¯"
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "1": [], "2": [], "3": [],
            "4": [], "5": []
        }
    },

    "hyprland/window": {
        "format": "َ°£† {}",
        "format-empty": "Desktop",
        "max-length": 18,
        "separate-outputs": true
    },

    "custom/active-window": {
        "exec": "~/.config/waybar/scripts/active-window.sh",
        "return-type": "json",
        "interval": 1,
        "tooltip": true
    },

    "clock": {
        "format": "َ°¥” {:%H:%M}",
        "format-alt": "َ°ƒ­ {:%d/%m/%Y  َ°¥” %H:%M:%S}",
        "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "custom/media": {
        "exec": "~/.config/waybar/scripts/media-scroll.sh",
        "return-type": "json",
        "interval": 1,
        "on-click": "bash ~/.config/hypr/scripts/ags-media.sh open",
        "on-click-right": "bash ~/.config/hypr/scripts/ags-media.sh play-pause",
        "on-click-middle": "bash ~/.config/hypr/scripts/ags-media.sh next-player",
        "on-scroll-up": "bash ~/.config/hypr/scripts/ags-media.sh previous",
        "on-scroll-down": "bash ~/.config/hypr/scripts/ags-media.sh next"
    },

    "temperature": {
        "thermal-zone": 9,
        "format": "َ°”ڈ {temperatureC}آ°C",
        "critical-threshold": 85,
        "format-critical": "َ±ƒ‚ {temperatureC}آ°C",
        "interval": 2,
        "tooltip": false
    },

    "cpu": {
        "format": "َ°کڑ {usage}%",
        "interval": 2,
        "tooltip": false,
        "states": { "warning": 70, "critical": 90 }
    },

    "memory": {
        "format": "َ°چ› {used:.1f}G",
        "interval": 2,
        "tooltip-format": "Used: {used:.1f}G / {total:.1f}G\nSwap: {swapUsed:.1f}G / {swapTotal:.1f}G",
        "states": { "warning": 70, "critical": 90 }
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°…¶",
            "deactivated": "َ°¾ھ"
        },
        "tooltip-format-activated": "Idle inhibitor: ON",
        "tooltip-format-deactivated": "Idle inhibitor: OFF"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["َ°‹™", "َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "brightnessctl -e4 -n2 set 5%+",
        "on-scroll-down": "brightnessctl -e4 -n2 set 5%-",
        "tooltip": false
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں",
        "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"],
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "max-volume": 150
    },

    "network": {
        "format-wifi": "َ°–© {signalStrength}%",
        "format-ethernet": "َ°ˆ€ {ipaddr}",
        "format-disconnected": "َ°Œ™",
        "format-linked": "َ°Œک",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr} / {cidr}\n{frequency} GHz",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr} / {cidr}",
        "on-click": "nm-connection-editor"
    },

    "bluetooth": {
        "format": "َ°‚¯",
        "format-disabled": "َ°‚²",
        "format-connected": "َ°‚± {num_connections}",
        "tooltip-format": "{controller_alias}  {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}  {device_address}  {device_battery_percentage}%",
        "on-click": "blueman-manager"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip-format": "{timeTo}\n{power:.1f}W\n{capacity}% charged"
    },

    "tray": {
        "spacing": 10
    },

    "custom/launcher": {
        "format": "َ°£‡",
        "tooltip": false,
        "on-click": "rofi -show drun"
    },

    "custom/conn-toggle": {
        "format": "َ°‹ٹ",
        "tooltip": false
    },

    "custom/tray-toggle": {
        "format": "َ°چœ",
        "tooltip": false
    },

    "custom/res-toggle": {
        "format": "َ°» ",
        "tooltip": false,
        "on-click": "sh -c 'resources || missioncenter || gnome-system-monitor || plasma-systemmonitor || true'"
    },

    "custom/control": {
        "format": "َ°’“",
        "tooltip": false,
        "on-click": "bash ~/.config/waybar/scripts/control-menu.sh"
    },

    "custom/power-profile": {
        "exec": "powerprofilesctl get | awk '{if ($0 == \"performance\") print \"َ°“…\"; else if ($0 == \"balanced\") print \"َ°¾…\"; else print \"َ°Œھ\"}'",
        "interval": 2,
        "format": "{}",
        "on-click": "bash ~/.config/waybar/scripts/power-profile-menu.sh",
        "tooltip-format": "Power profile",
        "tooltip": false
    },

    "custom/fcitx": {
        "exec": "fcitx5-remote -n | awk '{if ($0 == \"keyboard-us\") print \"EN\"; else print \"VI\"}'",
        "interval": 1,
        "format": "{}",
        "on-click": "fcitx5-remote -t",
        "tooltip": false
    },

    "custom/swaync": {
        "tooltip": false,
        "format": "{icon} {text}",
        "format-icons": {
            "notification": "َ°‚ڑ",
            "none": "َ°‚œ",
            "dnd-notification": "َ°‚›",
            "dnd-none": "َ°ھ‘",
            "inhibited-notification": "َ°‚ڑ",
            "inhibited-none": "َ°‚œ",
            "dnd-inhibited-notification": "َ°‚›",
            "dnd-inhibited-none": "َ°ھ‘"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": false,
        "on-click": "bash ~/.config/waybar/scripts/power-menu.sh"
    }
}
