// ── helpers ──────────────────────────────────────────────────────
function makeScale(min: number, max: number, step: number): Gtk.Scale {
    const scale = new Gtk.Scale({
        orientation: Gtk.Orientation.HORIZONTAL,
        drawValue: false,
        hexpand: true,
    })
    scale.set_range(min, max)
    scale.set_increments(step, step * 2)
    return scale
}

function clearBox(box: Gtk.Box) {
    let child = box.get_first_child()
    while (child) {
        const next = child.get_next_sibling()
        box.remove(child)
        child = next
    }
}

function wifiStrengthLabel(strength = 0) {
    if (strength >= 80) return "Excellent"
    if (strength >= 60) return "Good"
    if (strength >= 40) return "Fair"
    return "Weak"
}

function formatDuration(seconds = 0) {
    if (seconds < 0 || !Number.isFinite(seconds)) return "--:--"
    const total = Math.max(0, Math.floor(seconds))
    const mins = Math.floor(total / 60)
    const secs = total % 60
    return `${mins}:${String(secs).padStart(2, "0")}`
}

function playbackStatusLabel(status: unknown) {
    const normalized = String(status ?? "").toLowerCase()
    if (normalized.includes("play")) return "Playing"
    if (normalized.includes("pause")) return "Paused"
    if (normalized.includes("stop")) return "Stopped"
    return "Idle"
}

function currentPlayer() {
    const manager = Mpris.get_default()
    const players = [...manager.players]
    return players.find((player) => String(player.playbackStatus ?? "").toLowerCase().includes("play"))
        ?? players[0]
        ?? null
}

function mediaSnapshot() {
    const player = currentPlayer()
    if (!player) {
        return {
            available: false,
            title: "No media playing",
            artist: "Start playback in a supported app",
            album: "",
            status: "Idle",
            position: "--:--",
            length: "--:--",
            fraction: 0,
            canGoPrevious: false,
            canGoNext: false,
            canToggle: false,
        }
    }

    const length = Math.max(0, Number(player.length ?? 0))
    const position = Math.max(0, Math.min(Number(player.position ?? 0), length || Number.MAX_SAFE_INTEGER))
    const fraction = length > 0 ? Math.min(1, position / length) : 0

    return {
        available: true,
        title: player.title || "Unknown track",
        artist: player.artist || player.album || "Unknown artist",
        album: player.album || "",
        status: playbackStatusLabel(player.playbackStatus),
        position: formatDuration(position),
        length: formatDuration(length),
        fraction,
        canGoPrevious: Boolean(player.canGoPrevious),
        canGoNext: Boolean(player.canGoNext),
        canToggle: Boolean(player.canControl && (player.canPlay || player.canPause)),
    }
}

function speakerSnapshot() {
    const audio = Wp.get_default()?.audio
    const defaultSpeaker = audio?.defaultSpeaker
    const speakers = [...(audio?.speakers ?? [])]
        .filter((speaker) => Boolean(speaker.description || speaker.name))
        .slice(0, 4)
        .map((speaker) => ({
            id: speaker.id,
            label: speaker.description || speaker.name || "Unknown output",
            active: Boolean(speaker.is_default),
            volume: Math.round((speaker.volume ?? 0) * 100),
        }))

    return {
        current: defaultSpeaker?.description || defaultSpeaker?.name || "No output detected",
        speakers,
    }
}

function buildDetailsHeader(title: string, subtitle: string, onClose: () => void) {
    const row = new Gtk.Box({
        orientation: Gtk.Orientation.HORIZONTAL,
        spacing: 8,
    })

    const text = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 0,
        hexpand: true,
    })

    const titleLabel = new Gtk.Label({ label: title, halign: Gtk.Align.START })
    titleLabel.add_css_class("details-title")

    const subtitleLabel = new Gtk.Label({ label: subtitle, halign: Gtk.Align.START })
    subtitleLabel.add_css_class("details-hint")

    const close = new Gtk.Button({ label: "Close" })
    close.add_css_class("details-close")
    close.connect("clicked", onClose)

    text.append(titleLabel)
    text.append(subtitleLabel)
    row.append(text)
    row.append(close)

    return row
}

function makeDetailsPanel() {
    const panel = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 8,
    })
    panel.add_css_class("details-panel")
    return panel
}

function makeHintLabel(text: string) {
    const hint = new Gtk.Label({ label: text, halign: Gtk.Align.START })
    hint.add_css_class("details-hint")
    return hint
}

function relayoutWindow(win: Astal.Window, content: Gtk.Widget) {
    GLib.idle_add(GLib.PRIORITY_DEFAULT_IDLE, () => {
        content.queue_resize()
        win.queue_resize()
        win.set_default_size(-1, -1)
        return GLib.SOURCE_REMOVE
    })
}

function makeDetailsRow(
    title: string,
    subtitle: string,
    badge: string,
    current: boolean,
    sensitive: boolean,
    onClick: () => void,
) {
    const button = new Gtk.Button({ sensitive })
    button.add_css_class("details-row")
    if (current) button.add_css_class("current")
    button.connect("clicked", onClick)

    const row = new Gtk.Box({
        orientation: Gtk.Orientation.HORIZONTAL,
        spacing: 10,
    })

    const text = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 0,
        hexpand: true,
    })

    const titleLabel = new Gtk.Label({ label: title, halign: Gtk.Align.START })
    titleLabel.add_css_class("details-row-title")

    const subtitleLabel = new Gtk.Label({ label: subtitle, halign: Gtk.Align.START })
    subtitleLabel.add_css_class("details-row-subtitle")

    const badgeLabel = new Gtk.Label({ label: badge, valign: Gtk.Align.CENTER })
    badgeLabel.add_css_class("details-row-badge")

    text.append(titleLabel)
    text.append(subtitleLabel)
    row.append(text)
    row.append(badgeLabel)
    button.set_child(row)

    return button
}

function NowPlayingCard() {
    const snapshot = createPoll(mediaSnapshot(), 2000, mediaSnapshot)

    const title = new Gtk.Label({ halign: Gtk.Align.START, xalign: 0, hexpand: true })
    title.add_css_class("media-track")
    title.set_max_width_chars(28)
    title.set_ellipsize(3)

    const artist = new Gtk.Label({ halign: Gtk.Align.START, xalign: 0, hexpand: true })
    artist.add_css_class("media-subtitle")
    artist.set_max_width_chars(28)
    artist.set_ellipsize(3)

    const meta = new Gtk.Label({ halign: Gtk.Align.START, xalign: 0, hexpand: true })
    meta.add_css_class("media-meta")
    meta.set_max_width_chars(28)
    meta.set_ellipsize(3)

    const progress = new Gtk.ProgressBar({ hexpand: true, valign: Gtk.Align.CENTER })
    progress.add_css_class("media-progress")

    const start = new Gtk.Label({ label: "--:--", halign: Gtk.Align.START, xalign: 0 })
    start.add_css_class("media-time")

    const end = new Gtk.Label({ label: "--:--", halign: Gtk.Align.END, xalign: 1 })
    end.add_css_class("media-time")

    const previous = new Gtk.Button({ label: "󰒮" })
    previous.add_css_class("media-control")
    previous.connect("clicked", () => currentPlayer()?.previous())

    const playPause = new Gtk.Button({ label: "󰐊" })
    playPause.add_css_class("media-control")
    playPause.add_css_class("primary")
    playPause.connect("clicked", () => currentPlayer()?.play_pause())

    const next = new Gtk.Button({ label: "󰒭" })
    next.add_css_class("media-control")
    next.connect("clicked", () => currentPlayer()?.next())

    createEffect(() => {
        const data = snapshot()
        title.set_label(data.title)
        artist.set_label(data.artist)
        meta.set_label(data.available ? `${data.status}${data.album ? ` • ${data.album}` : ""}` : data.status)
        progress.set_fraction(data.fraction)
        start.set_label(data.position)
        end.set_label(data.length)
        previous.set_sensitive(data.canGoPrevious)
        next.set_sensitive(data.canGoNext)
        playPause.set_sensitive(data.canToggle)
        playPause.set_label(data.status === "Playing" ? "󰏤" : "󰐊")
    })

    return (
        <box class="media-card compact" orientation={Gtk.Orientation.VERTICAL} spacing={8}>
            <box orientation={Gtk.Orientation.HORIZONTAL} spacing={8}>
                <box orientation={Gtk.Orientation.VERTICAL} spacing={1} hexpand>
                    <Gtk.Label class="media-title" label="Now Playing" halign={Gtk.Align.START} />
                    {title}
                    {artist}
                    {meta}
                </box>
                <box class="media-controls compact" spacing={4} valign={Gtk.Align.CENTER}>
                    {previous}
                    {playPause}
                    {next}
                </box>
            </box>
            {progress}
            <box orientation={Gtk.Orientation.HORIZONTAL}>
                {start}
                <box hexpand />
                {end}
            </box>
        </box>
    )
}

function AudioOutputCard() {
    const snapshot = createPoll(speakerSnapshot(), 2000, speakerSnapshot)
    const outputs = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 6,
    })

    const current = new Gtk.Label({ halign: Gtk.Align.START, xalign: 0, hexpand: true })
    current.add_css_class("output-current")
    current.set_max_width_chars(34)
    current.set_ellipsize(3)

    const subtitle = new Gtk.Label({ halign: Gtk.Align.START, xalign: 0 })
    subtitle.add_css_class("details-hint")

    const renderOutputs = () => {
        clearBox(outputs)
        const audio = Wp.get_default()?.audio
        const data = snapshot()

        if (data.speakers.length === 0) {
            const empty = new Gtk.Label({ label: "No outputs available", halign: Gtk.Align.START, xalign: 0 })
            empty.add_css_class("details-hint")
            outputs.append(empty)
            return
        }

        data.speakers.slice(0, 3).forEach((speakerData) => {
            const speaker = [...(audio?.speakers ?? [])].find((item) => item.id === speakerData.id)
            outputs.append(makeDetailsRow(
                speakerData.label,
                `Output • ${speakerData.volume}%`,
                speakerData.active ? "Current" : "",
                speakerData.active,
                true,
                () => speaker?.set_is_default(true),
            ))
        })
    }

    createEffect(() => {
        const data = snapshot()
        current.set_label(`Current output: ${data.current}`)
        subtitle.set_label(data.speakers.length > 1 ? "Tap to switch output" : "Single active output detected")
        renderOutputs()
    })

    return (
        <box class="output-card compact" orientation={Gtk.Orientation.VERTICAL} spacing={6}>
            <Gtk.Label class="media-title" label="Sound Output" halign={Gtk.Align.START} />
            {current}
            {subtitle}
            {outputs}
        </box>
    )
}

// ── WiFi Toggle ──────────────────────────────────────────────────
function WifiToggle({ onDetails }: { onDetails: () => void }) {
    const network = Network.get_default()
    const wifi = network?.wifi

    return (
        <box class="toggle-card" orientation={Gtk.Orientation.HORIZONTAL} spacing={10}>
            <Gtk.Button class="toggle-main" hexpand onClicked={onDetails}>
                <box orientation={Gtk.Orientation.VERTICAL} hexpand>
                    <Gtk.Label class="toggle-title" label="Wi-Fi" halign={Gtk.Align.START} />
                    <Gtk.Label
                        class="toggle-subtitle"
                        label={wifi ? createBinding(wifi, "ssid")((s) => s ?? "Disconnected") : "No adapter"}
                        halign={Gtk.Align.START}
                        maxWidthChars={14}
                        ellipsize={3}
                    />
                </box>
            </Gtk.Button>
            {wifi && (
                <Gtk.Switch
                    active={createBinding(wifi, "enabled")}
                    valign={Gtk.Align.CENTER}
                    onStateSet={(_, state) => { wifi.enabled = state; return false }}
                />
            )}
        </box>
    )
}

